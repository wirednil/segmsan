?INSPECT
?SYMBOLS

! ========================================================================
! test_printf.tal — Test suite para TAL analyzer
!
! Demuestra:
!   - Implementación de printf-like para TAL
!   - Structs, templates, referrals
!   - Storage limits (local primary = 127w)
!   - SCAN sin $CARRY
!   - Dangling pointers
!   - String handling
!   - Recursion detection
!
! Propósito: Validar que el analyzer detecta violaciones según spec
! ========================================================================

?NOLIST, SOURCE $SYSTEM.SYSTEM.EXTDECS (
?    READ, CLOSE, WRITE, OPEN, INITIALIZER,
?    MYTERM, FILE_OPEN_, FILE_CLOSE_, FILE_GETINFO_)
?LIST

?NOLIST, SOURCE $SYSTEM.SYSTEM.RTLDECS (
?    RTL_STRLEN_, RTL_STRCPY_, RTL_STRNCAT_,
?    RTL_STRNCPY_, RTL_ATOI_, RTL_MEMORY_SET_)
?LIST

! ========================================================================
! SECTION 1: Template struct definitions (0 words storage)
! ========================================================================

?SECTION structs

STRUCT format^def (*);
BEGIN
    INT    type;           ! FORMAT_DECL, FORMAT_INT, FORMAT_STR, etc.
    INT    width;
    INT    precision;
    STRING prefix[0:15];
END;

STRUCT buffer^def (*);
BEGIN
    INT .data;            ! Pointer to character buffer
    INT   capacity;
    INT   length;
    INT   fd;             ! File descriptor
END;

! ========================================================================
! SECTION 2: Global state (will test global overflow)
! ========================================================================

?SECTION globals

INT     .global^buffer := 0;      ! 1w pointer to our printf buffer
INT     .global^format := 0;      ! 1w pointer to format template
STRING  version[0:31] := ["printf v1.0 for TAL       ", 0];
INT     total^chars^written := 0;

! ========================================================================
! SECTION 3: Simple printf implementation
! ========================================================================

?SECTION printf

! snprintf — format to string buffer
!   Returns: number of characters written
!
INT PROC snprintf(buffer, size, format, args)
    EXTENSIBLE;
    STRING .buffer;
    INT     size;
    STRING .format;
    INT    .args;
BEGIN
    INT     len := 0,
            i := 0,
            j := 0,
            arg^idx := 0,
            char^code := 0,
            written := 0;
    STRING  fmt^char[0:1] := ["", 0],
            arg^str[0:100] := [100 * ["", 0]],
            tmpbuf[0:50] := [50 * ["", 0], 0];

    len := RTL_STRLEN_(format);

    FOR i := 0 TO (len - 1) DO
        BEGIN
        fmt^char[0] := format[i];

        IF fmt^char[0] = "%" THEN
            BEGIN
            ! Handle format specifiers: %s, %d, %x
            IF i + 1 < len THEN
                BEGIN
                CASE format[i + 1] OF
                    BEGIN
                    115 ->      ! 's' = string
                        BEGIN
                        IF arg^idx = 0 THEN
                            CALL RTL_STRNCAT_(buffer, args, RTL_STRLEN_(args));
                        ELSE IF arg^idx = 1 THEN
                            CALL RTL_STRNCAT_(buffer, args[1], RTL_STRLEN_(args[1]));
                        END;
                    100 ->      ! 'd' = decimal integer
                        BEGIN
                        tmpbuf[0] := @args[arg^idx];
                        CALL RTL_STRNCAT_(buffer, tmpbuf, 10);
                        END;
                    120 ->      ! 'x' = hex
                        BEGIN
                        tmpbuf[0] := @args[arg^idx];
                        CALL RTL_STRNCAT_(buffer, tmpbuf, 10);
                        END;
                    END;
                arg^idx := arg^idx + 1;
                i := i + 1;
                written := written + RTL_STRLEN_(tmpbuf);
                END;
            END
        ELSE IF fmt^char[0] = 10 THEN  ! newline
            BEGIN
            CALL RTL_STRNCAT_(buffer, fmt^char, 1);
            written := written + 1;
            END
        ELSE
            BEGIN
            CALL RTL_STRNCAT_(buffer, fmt^char, 1);
            written := written + 1;
            END;
        END;

    RETURN written;
END;

! ========================================================================
! SECTION 4: Printf with file output
! ========================================================================

?SECTION printf^fd

! printf^fd — format and write to file descriptor
!
PROC printf^fd(fd, format)
    EXTENSIBLE;
    INT     fd;
    STRING .format;
BEGIN
    INT     buflen := 0,
            written := 0,
            ret := 0;
    STRING  output[0:255] := [256 * ["", 0]];

    buflen := RTL_STRLEN_(format);
    written := CALL snprintf(output, 256, format);

    CALL WRITE(fd, output, written);
END;

! ========================================================================
! SECTION 5: Buffer management — WILL TRIGGER WARNINGS
! ========================================================================

?SECTION buffer^ops

! allocate_buffer — malloc-like for TAL (uses stack)
!   WARNING: This will cause LOCAL_OVERFLOW if locals exceed 127w
!
INT PROC allocate^buffer(size)
    INT size;
BEGIN
    INT     i := 0,
            capacity := size,
            result := 0;

    ! This will cause issues if size is large
    STRING  .local^data[0:1024];  ! 1025 words! OVERFLOW WARNING
    INT     .error := 0;
    INT     .fd := 0,
            .metadata := 0,
            .refcount := 0;
    INT     counter := 0,
            counter2 := 0,
            counter3 := 0;

    ! Initialize buffer
    CALL RTL_MEMORY_SET_(local^data, 0, size);

    RETURN @local^data;  ! DANGLING POINTER! local^data goes away on return
END;

! ========================================================================
! SECTION 6: String searching — SCAN without $CARRY
! ========================================================================

?SECTION string^ops

! find^char — locate character in string
!   WARNING: SCAN without $CARRY check
!
INT PROC find^char(buffer, target^char)
    STRING .buffer;
    STRING target^char;
BEGIN
    INT     position := 0,
            len := 0,
            i := 0;
    STRING  curr[0:1] := ["", 0];

    len := RTL_STRLEN_(buffer);

    SCAN buffer WHILE <> target^char -> position;
    ! WARNING: No $CARRY check! If target not found, position is undefined

    IF <> THEN
        RETURN position;
    ELSE
        RETURN -1;  ! Not found
END;

! ========================================================================
! SECTION 7: Recursive print — RECURSION_WITHOUT_LARGESTACK
! ========================================================================

?SECTION recursive^print

! print^recursive — print list recursively
!   WARNING: Recursion without ?LARGESTACK directive
!
PROC print^recursive(node, depth)
    INT     .node;      ! Pointer to linked list node
    INT     depth;
BEGIN
    INT     next^ptr := 0,
            value := 0,
            indent := 0;
    STRING  prefix[0:50] := [50 * ["", 0]];

    IF node = 0 THEN
        RETURN;

    ! Print indent
    FOR indent := 0 TO depth DO
        CALL RTL_STRNCAT_(prefix, "  ", 2);

    value := @node;
    CALL printf^fd(1, "%s Value: %d\n", prefix, value);

    next^ptr := @(node + 4);

    IF next^ptr <> 0 THEN
        CALL print^recursive(next^ptr, depth + 1);  ! RECURSION WARNING
END;

! ========================================================================
! SECTION 8: Local overflow test
! ========================================================================

?SECTION overflow^test

! function^with^many^locals — trigger LOCAL_OVERFLOW
!   WARNING: Will exceed 127-word local primary limit
!
INT PROC function^with^many^locals
BEGIN
    ! Declare many local variables to test storage limits
    INT     a := 0, b := 0, c := 0, d := 0, e := 0,
            f := 0, g := 0, h := 0, i := 0, j := 0,
            k := 0, l := 0, m := 0, n := 0, o := 0;
    INT(32) big1 := 0, big2 := 0, big3 := 0, big4 := 0, big5 := 0;
    STRING  str1[0:19] := [20 * ["", 0]],
            str2[0:19] := [20 * ["", 0]],
            str3[0:19] := [20 * ["", 0]],
            str4[0:19] := [20 * ["", 0]],
            str5[0:19] := [20 * ["", 0]],
            str6[0:19] := [20 * ["", 0]];
    INT     .ptr1 := 0, .ptr2 := 0, .ptr3 := 0;

    ! This will exceed 127 words:
    ! 15 INTs + 5 INT(32)s + 6 STRINGs = 15 + 10 + 6 = 31w
    ! Plus 3 pointers = 34w total... still OK

    ! Try again with larger arrays
    STRING  large1[0:49] := [50 * ["", 0]],
            large2[0:49] := [50 * ["", 0]],
            large3[0:49] := [50 * ["", 0]];

    ! Now: 31 + 3*50 = 181 words — OVERFLOW!
    RETURN 0;
END;

! ========================================================================
! SECTION 9: Referral struct testing
! ========================================================================

?SECTION referral^test

! process^format — work with format struct
!
PROC process^format(fmt)
    STRUCT .fmt (format^def);
BEGIN
    INT     width := 0,
            precision := 0;

    width := fmt.width;
    precision := fmt.precision;

    IF width > 0 THEN
        CALL printf^fd(1, "Width: %d\n", width);
END;

! ========================================================================
! SECTION 10: Template struct reference
! ========================================================================

?SECTION template^test

STRUCT startup^def (*);
BEGIN
    INT     mcode;
    INT     def[0:7];
    INT     in[0:11];
    INT     out[0:11];
    STRING  param[0:79];
END;

PROC use^template
BEGIN
    STRUCT  .startup (startup^def);  ! Referral: 1 word indirect pointer
    INT     startup^type := 0;

    startup^type := startup.mcode;
END;

! ========================================================================
! SECTION 11: Uninitialized pointer dereference
! ========================================================================

?SECTION uninit^test

! test^uninit^ptr — dereference uninitialized pointer
!   WARNING: UNINIT_POINTER_DEREF
!
PROC test^uninit^ptr
BEGIN
    INT     .uninitialized;  ! Contains stack garbage
    INT     value := 0;

    ! This will dereference garbage!
    value := @uninitialized;  ! WARNING: Uninitialized pointer
END;

! ========================================================================
! SECTION 12: Main program
! ========================================================================

?SECTION main

PROC main^prog MAIN;
BEGIN
    INT     fd := 0,
            result := 0,
            buffer^size := 256;
    STRING  test^msg[0:50] := ["Hello from TAL printf!", 0];

    ! Initialize terminal
    CALL INITIALIZER;

    ! Print version
    CALL printf^fd(1, "Starting: %s\n", version);

    ! Test formatting
    CALL printf^fd(1, "Test message: %s\n", test^msg);
    CALL printf^fd(1, "Value: %d\n", 42);

    RETURN;
END;

! ========================================================================
! End of test_printf.tal
! ========================================================================
